{
  "name": "nest-js-core-graphql",
  "version": "0.0.1",
  "description": "NestJs Core Graphql",
  "author": "Arash Alfooneh",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "studio:dev": "env-cmd -f ./.env.dev pnpm prisma studio",
    "prisma:studio:dev": "env-cmd -f ./.env.dev pnpm prisma studio",
    "prisma:generate:dev": "env-cmd -f ./.env.dev prisma generate",
    "prisma:migrate:dev": "env-cmd -f ./.env.dev prisma migrate dev",
    "prisma:push:dev": "env-cmd -f ./.env.dev prisma db push",
    "start:build": "env-cmd -f ./.env.prod nest build",
    "start:prod": "env-cmd -f ./.env.prod node dist/main.js",
    "start:dev": "env-cmd -f ./.env.dev nest start --webpack --webpackPath ./webpack-hmr.config.js --watch",
    "test": "env-cmd -f ./.env.test jest --config jest.config.js --detectOpenHandles --forceExit",
    "test:cov": "env-cmd -f ./.env.test jest --config jest.config.js  --detectOpenHandles --forceExit --coverage",
    "api": "npx ts-node scripts/zeus.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@swc/helpers": "^0.5.23",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clean-deep": "^3.4.0",
    "fastify": "^5.8.5",
    "graphql": "^16.14.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^13.0.2"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "chokidar": "^4.0.3",
    "commitizen": "^4.3.2",
    "commitlint-config-gitmoji": "^2.3.1",
    "cz-customizable": "^7.5.4",
    "env-cmd": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "graphql-zeus": "^7.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "run-script-webpack-plugin": "^0.2.3",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-node-externals": "^3.0.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "config/path/to/my/config.js"
    }
  }
}
