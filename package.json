{
  "name": "nest-js-core-graphql",
  "version": "0.0.1",
  "description": "NestJs Core Graphql",
  "author": "Arash Alfooneh",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "api": "env-cmd -f ./.env.dev npx ts-node scripts/zeus.ts",
    "doc": "npx compodoc -p tsconfig.json -n 'NestJs Core Rest'",
    "start:build": "env-cmd -f ./.env.prod npx swc --delete-dir-on-start --out-dir dist/ src/",
    "start:prod": "env-cmd -f ./.env.prod node dist/src/main.js",
    "start:dev": "env-cmd -f ./.env.dev nest build --webpack --webpackPath ./src/webpack-hmr.config.js --watch",
    "start:build:docker": "swc --delete-dir-on-start --out-dir dist/ src/",
    "start:prod:docker": "npx prisma generate && npx prisma db push && node dist/src/main.js",
    "start:dev:docker": "npx prisma generate && npx prisma db push && nest build --webpack --webpackPath ./src/webpack-hmr.config.js --watch",
    "test:migrate": "env-cmd -f ./.env.test npx prisma db push",
    "test:e2e": "env-cmd -f ./.env.test jest --config jest.config.js --detectOpenHandles --forceExit ",
    "test:cov": "env-cmd -f ./.env.test jest --config jest.config.js  --detectOpenHandles --forceExit --coverage"
  },
  "dependencies": {
    "@apollo/server": "^4.10.2",
    "@as-integrations/fastify": "^2.1.1",
    "@fastify/static": "^7.0.2",
    "@nanogiants/nestjs-swagger-api-exception-decorator": "^1.6.11",
    "@nestjs/apollo": "^12.1.0",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.3.7",
    "@nestjs/config": "^3.2.1",
    "@nestjs/core": "^10.3.7",
    "@nestjs/graphql": "^12.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "10.3.7",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/swagger": "^7.3.1",
    "@prisma/client": "^5.11.0",
    "@swc/cli": "^0.3.12",
    "@swc/core": "^1.4.11",
    "@types/express": "^4.17.17",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "axios": "^1.6.8",
    "class-transformer": "^0.5.1",
    "class-validator": "0.14.1",
    "clean-deep": "^3.4.0",
    "deepmerge": "^4.3.1",
    "env-cmd": "^10.1.0",
    "fastify": "^4.26.2",
    "graphql": "^16.8.1",
    "hasha": "^5.2.2",
    "husky": "^9.0.11",
    "nestjs-loki-logger": "^0.1.0",
    "prisma": "5.11.0",
    "run-script-webpack-plugin": "^0.2.0",
    "rxjs": "^7.8.1",
    "ts-loader": "^9.5.1",
    "tslib": "^2.6.2",
    "webpack": "^5.91.0",
    "webpack-node-externals": "^3.0.0"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.23",
    "@nestjs/testing": "^10.3.7",
    "@stylistic/eslint-plugin-js": "^1.7.0",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.2",
    "@typescript-eslint/eslint-plugin": "^7.5.0",
    "chokidar": "^3.5.3",
    "commitizen": "^4.3.0",
    "commitlint-config-gitmoji": "^2.3.1",
    "cz-customizable": "^7.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "jest": "^29.5.0",
    "lint-staged": "^15.2.2",
    "prettier": "3.2.5",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "config/path/to/my/config.js"
    }
  }
}
