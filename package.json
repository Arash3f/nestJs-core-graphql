{
  "name": "nest-js-core-graphql",
  "version": "0.0.1",
  "description": "NestJs Core Graphql",
  "author": "Arash Alfooneh",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "api": "npx ts-node scripts/zeus.ts",
    "doc": "npx compodoc -p tsconfig.json -n 'NestJs Core Rest'",
    "start:build": "env-cmd -f ./.env.prod nest build",
    "start:prod": "env-cmd -f ./.env.prod node dist/main.js",
    "start:dev": "env-cmd -f ./.env.dev nest build --webpack --webpackPath ./src/webpack-hmr.config.js --watch",
    "start:build:docker": "nest build",
    "start:prod:docker": "npx prisma generate && npx prisma db push && node dist/main.js",
    "start:dev:docker": "npx prisma generate && npx prisma db push && nest build --webpack --webpackPath ./src/webpack-hmr.config.js --watch",
    "typecheck": "tsc --noEmit",
    "test:migrate": "env-cmd -f ./.env.test npx prisma db push",
    "test:e2e": "env-cmd -f ./.env.test jest --config jest.config.js --detectOpenHandles --forceExit ",
    "test:cov": "env-cmd -f ./.env.test jest --config jest.config.js  --detectOpenHandles --forceExit --coverage",
    "prisma:generate:dev": "env-cmd -f ./.env.dev prisma generate",
    "prisma:migrate:dev": "env-cmd -f ./.env.dev prisma migrate dev",
    "prisma:push:dev": "env-cmd -f ./.env.dev prisma db push"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@swc/helpers": "^0.5.23",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clean-deep": "^3.4.0",
    "fastify": "^5.8.5",
    "graphql": "^16.11.0",
    "nestjs-loki-logger": "^0.1.0",
    "node-fetch": "^2.7.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.6.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.1.26",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.41",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^24.10.1",
    "@types/node-fetch": "^2.6.11",
    "@types/ws": "^8.18.1",
    "chokidar": "^4.0.3",
    "commitizen": "^4.3.1",
    "commitlint-config-gitmoji": "^2.3.1",
    "cz-customizable": "^7.4.0",
    "env-cmd": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "run-script-webpack-plugin": "^0.2.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.97.1",
    "webpack-node-externals": "^3.0.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "config/path/to/my/config.js"
    }
  }
}
