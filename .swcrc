{
  "$schema": "https://swc.rs/schema.json",
  "exclude": [".*\\.spec\\.ts$", "src/utils/.*", ".*[\\\\/]utils[\\\\/]graphql[\\\\/].*"],
  "sourceMaps": true,
  "module": {
    "type": "commonjs"
  },
  "jsc": {
    "target": "es2021",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true,
      "useDefineForClassFields": false
    },
    "keepClassNames": true,
    "baseUrl": "./",
    "paths": {
      "@src/*": ["src/*"]
    }
  },
  "minify": false
}
