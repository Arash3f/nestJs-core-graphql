{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "incremental": true,
    "tsBuildInfoFile": "./dist/build-info.json",
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@src/*": [
        "./src/*"
      ]
    }
  },
  "typedocOptions": {
    "out": "doc",
    "exclude": "**/node_modules/**"
  },
  "include": [
    "./src/**/*",
    "./scripts/**/*",
    "./prisma.config.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/doc/**",
    "**/coverage/**",
    "**/swagger/**"
  ]
}
