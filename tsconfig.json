{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDirs": [
      "./src",
      "./scripts/generate-api.ts"
    ],
    "removeComments": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "incremental": true,
    "tsBuildInfoFile": "./dist/build-info.json",
    "paths": {
      "@src/*": [
        "./src/*"
      ]
    }
  },
  "typedocOptions": {
    "out": "doc",
    "exclude": "**/node_modules/**",
  },
  "includes": [
    "./src/**/*",
    "./scripts/generate-api.ts",
  ],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/doc/**",
    "**/coverage/**",
    "**/zeus/**",
    "**/swagger/**"
  ]
}