generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id       String  @id @default(uuid()) @db.Uuid
  username String  @unique
  password String
  name     String
  active   Boolean @default(true)
  role     Role    @default(Member)

  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt()
}

enum Role {
  Admin
  Member
}
