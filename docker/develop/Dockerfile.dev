# Dockerfile.dev
FROM node:22.22.3-alpine AS development

# Keep the package manager aligned with package.json and CI.
RUN npm install -g pnpm@10.33.0

WORKDIR /app

ENV PNPM_IGNORE_AGE_POLICY=true
ENV PNPM_IGNORE_PATH_POLICY=true
ENV PNPM_IGNORE_REGISTRY_POLICY=true

COPY --chown=node:node package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store pnpm fetch --frozen-lockfile
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store pnpm install --frozen-lockfile --offline

COPY --chown=node:node . .

EXPOSE 3000
