NODE_ENV=development

# ! Server Config
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=3000

# ! CORS — comma-separated origins, or * for all
CORS_ORIGINS=*

# ! Rate limiting for auth endpoints (logIn, register, refreshToken)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=10

# ! JWT config section
JWT_SECRET=
JWT_ACCESS_EXPIRE=10000
JWT_REFRESH_EXPIRE=10000

# ! Database config section
# Host must remain `postgres` (the Compose service name). Credentials and DB name
# must match docker/develop/.docker.dev.env.
DATABASE_CONNECTION_URL=postgres://DATABASE_USERNAME:DATABASE_PASSWORD@postgres:5432/DATABASE_NAME

SEED_ON_BOOT=true

# ! Super user default data
SUPER_USER_NAME=admin
SUPER_USER_USERNAME=admin
SUPER_USER_PASSWORD=admin

# ! Member user default data (optional)
MEMBER_USER_NAME=member
MEMBER_USER_USERNAME=member
MEMBER_USER_PASSWORD=member

# ! Password hashing params
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_PARALLELISM=1
